{
  "info": {
    "_postman_id": "44444444-4444-4444-8444-444444444444",
    "name": "SWAPI People 1-5 Mockoon",
    "description": "Collection to consume the Mockoon mock API generated from https://swapi.info/api/people/{id} for IDs 1 to 5.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "People",
      "item": [
        {
          "name": "Get Luke Skywalker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns Luke Skywalker', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.name).to.eql('Luke Skywalker');",
                  "  pm.expect(json.url).to.eql('https://swapi.info/api/people/1');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/people/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "people",
                "1"
              ]
            }
          },
          "response": []
        },
